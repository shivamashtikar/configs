// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "vim_operator == none && !VimWaiting && vim_mode != insert && !Terminal && mode != single_line",
    "bindings": {
      "space o": "file_finder::Toggle",
      "space w": "workspace::Save",
      "space q q": "pane::CloseActiveItem",
      "space q w": ["workspace::SendKeystrokes", "escape : wq! enter"],
      "space q a": "workspace::CloseAllDocks",
      "space tab": "pane::AlternateFile",
      "shift-j": "vim::ScrollDown",
      "shift-k": "vim::ScrollUp",
      "ctrl-f": "vim::JoinLines",
      "shift-u": "vim::Redo",
      "space space": "project_panel::Toggle",
      "space f j": "pane::DeploySearch",
      "space f p": "pane::RevealInProjectPanel",
      "space g c o": "git::CheckoutBranch",
      "space g c c": "git::Commit",
      "space g p p": "git::Pull",
      "space g p r": "git::PullRebase",
      "space g p u": "git::Push",
      "space g g": "git::Diff",
      "space s v": "pane::SplitHorizontal",
      "space s s": "pane::SplitVertical",
      "space s k": "pane::SplitAndMoveRight",
      "space p": "projects::OpenRecent",
      "space y": [
        "action::Sequence",
        [
          "editor::SelectLargerSyntaxNode",
          "editor::Copy",
          "editor::UndoSelection",
        ],
      ],
      "g f": "editor::OpenExcerpts",
    },
  },
  // Empty pane, set of keybindings that are available when there is no active editor
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      // Open file finder
      "space space": "file_finder::Toggle",
      // Open recent project
      "space p": "projects::OpenRecent",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "alt-t": "workspace::NewTerminal",
      "alt-w": "pane::CloseActiveItem",
      "alt-=": "vim::GoToPreviousTab",
    },
  },
  // File panel (netrw)
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      // Close project panel as project file panel on the right
      "q": "workspace::ToggleLeftDock",
      "space e": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Dock|| (VimControl && !menu)",
    "bindings": {
      "alt-h": "workspace::ActivatePaneLeft",
      "alt-l": "workspace::ActivatePaneRight",
      "alt-k": "workspace::ActivatePaneUp",
      "alt-j": "workspace::ActivatePaneDown",
      "alt-q": "workspace::CloseActiveDock",
      "alt-`": "terminal_panel::Toggle",
      "alt-g": "git_panel::Toggle",
      "cmd-g": "git_panel::Toggle",
      "cmd-b": "project_panel::Toggle",
      "cmd-q": "workspace::CloseWindow",
    },
  },
  {
    "context": "Editor && vim_mode == visual && !menu && !Terminal",
    "bindings": {
      "shift-k": "editor::MoveLineUp",
      "shift-j": "editor::MoveLineDown",
    },
  },
  {
    "context": "",
    "bindings": {
      "alt-f": "workspace::ToggleZoom",
      "space f f": "file_finder::Toggle",
    },
  },
]
